# Supabase - Get from https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Database - Get from https://supabase.com/dashboard/project/_/settings/database
# Use "Session pooler" for DATABASE_URL (port 6543)
# Use "Direct connection" for DIRECT_URL (port 5432)
DATABASE_URL=postgresql://postgres.your-project:password@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.your-project:password@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ===========================================
# Admin API
# ===========================================

# Required: Admin secret for protected endpoints
# Generate a strong random string for production
ADMIN_SECRET=your-admin-secret-here

# ===========================================
# AI Configuration (DeepSeek)
# ===========================================

# Required: DeepSeek API Key - Get from https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# Optional: Timeouts (milliseconds) - defaults shown
# NEXT_PUBLIC_AI_REFINE_TIMEOUT_MS=30000    # Text refinement (Chat model)
# NEXT_PUBLIC_AI_GENERATE_TIMEOUT_MS=45000  # Complex generation (Reasoner)
# AI_SERVER_TIMEOUT_MS=40000                # Server-side timeout
# NEXT_PUBLIC_AI_COOLDOWN_MS=2000           # Cooldown between calls

# Optional: Context limits - defaults shown
# NEXT_PUBLIC_AI_MAX_DOCS=2                 # Max docs in AI context
# NEXT_PUBLIC_AI_MAX_TOKENS_PER_DOC=800     # Tokens per doc
# NEXT_PUBLIC_AI_MAX_TOKENS_FEATURE=500     # Feature context tokens
# NEXT_PUBLIC_AI_MAX_INPUT_CHARS=10000      # Max input characters

# Optional: Model configuration - defaults shown
# AI_MODEL_CHAT=deepseek-chat               # Fast/cheap model
# AI_MODEL_REASONER=deepseek-reasoner       # Complex reasoning model
# AI_TEMPERATURE_CREATIVE=0.7               # Creative tasks temp
# AI_TEMPERATURE_PRECISE=0.1                # Precise tasks temp

# Optional: Conversational agent chat provider
# Falls back to ZAI_* / DEEPSEEK_* and AI_MODEL_CHAT when omitted
# FLUXO_CHAT_API_URL=https://api.z.ai/api/coding/paas/v4
# FLUXO_CHAT_API_KEY=your-openai-compatible-key-here
# FLUXO_CHAT_MODEL=glm-4.7
# FLUXO_CHAT_API_HEADERS={"X-Custom-Header":"value"}

# Optional shortcuts when you already use Z.ai elsewhere
# ZAI_API_URL=https://api.z.ai/api/coding/paas/v4
# ZAI_API_KEY=***
# ZAI_MODEL=glm-4.7

# ===========================================
# Fluxo Agent API consumer skill
# ===========================================

# Required in repos that use the npm-installable skill
FLUXO_AGENT_KEY=agk-your-tenant-key-here

# Optional overrides for the skill helper
# FLUXO_AGENT_API_URL=http://localhost:3005/api/agent
# FLUXO_AGENT_NAME=Codex Skill

# ===========================================
# GitHub App Integration
# ===========================================

# Required for GitHub integration
# GITHUB_APP_ID=your-github-app-id
# GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
# GITHUB_WEBHOOK_SECRET=your-w...cret
# NEXT_PUBLIC_GITHUB_APP_ID=your-github-app-id
# NEXT_PUBLIC_GITHUB_APP_SLUG=fluxo-dev