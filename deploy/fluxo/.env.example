APP_DOMAIN=fluxo.agenda-aqui.com
TZ=America/Sao_Paulo
FLUXO_ENV_FILE=/opt/apps/fluxo/shared/config/fluxo.env
NEXT_PUBLIC_APP_URL=https://fluxo.agenda-aqui.com
NEXT_PUBLIC_BETTER_AUTH_URL=https://fluxo.agenda-aqui.com
NEXT_PUBLIC_ENABLE_REALTIME=false
SOURCE_PGSSLMODE=require
SOURCE_POSTGRES_CLIENT_IMAGE=postgres:17-alpine
TARGET_POSTGRES_CLIENT_IMAGE=postgres:17-alpine

FLUXO_APP_ROOT=/opt/apps/fluxo/current
FLUXO_POSTGRES_DATA_DIR=/opt/apps/fluxo/shared/postgres/data
FLUXO_POSTGRES_INIT_DIR=/opt/apps/fluxo/current/deploy/fluxo/postgres/init
FLUXO_POSTGRES_BACKUPS_DIR=/opt/apps/fluxo/shared/postgres/backups

POSTGRES_DB=fluxo
POSTGRES_USER=fluxo_app
POSTGRES_PASSWORD=change-me

DATABASE_URL=postgresql://fluxo_app:change-me@fluxo-postgres:5432/fluxo
DIRECT_URL=postgresql://fluxo_app:change-me@fluxo-postgres:5432/fluxo

# Current application variables while Supabase auth is still present.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Future Better Auth variables.
BETTER_AUTH_URL=https://fluxo.agenda-aqui.com
BETTER_AUTH_SECRET=change-me
FROM_DATABASE_URL=

# Application secrets.
DEEPSEEK_API_KEY=
ADMIN_SECRET=change-me

# Conversational agent chat provider.
# Prefer explicit FLUXO_CHAT_* if you want to isolate the chat provider from the rest of the AI stack.
# If omitted, the app can fall back to ZAI_* and then to DEEPSEEK_*.
FLUXO_CHAT_API_URL=
FLUXO_CHAT_API_KEY=
FLUXO_CHAT_MODEL=
FLUXO_CHAT_API_HEADERS=

# Optional direct Z.ai fallback for the conversational chat.
ZAI_API_URL=https://api.z.ai/api/paas/v4
ZAI_API_KEY=
ZAI_MODEL=glm-4.7-flash
