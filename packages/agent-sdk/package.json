{
  "name": "@guilherme/agent-sdk",
  "version": "0.1.1",
  "description": "SDK para criar AI agents com tools, streaming e UI pronta",
  "author": "Guilherme Koike",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./core": {
      "import": "./dist/core/index.js",
      "types": "./dist/core/index.d.ts"
    },
    "./react": {
      "import": "./dist/react/index.js",
      "types": "./dist/react/index.d.ts"
    },
    "./next": {
      "import": "./dist/next/index.js",
      "types": "./dist/next/index.d.ts"
    },
    "./mcp": {
      "import": "./dist/core/mcp.js",
      "types": "./dist/core/mcp.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\" && tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "next": ">=14",
    "react": ">=18",
    "react-dom": ">=18",
    "zod": ">=3",
    "@upstash/redis": ">=1",
    "ioredis": ">=5",
    "pg": ">=8",
    "better-sqlite3": ">=9"
  },
  "peerDependenciesMeta": {
    "@upstash/redis": { "optional": true },
    "ioredis": { "optional": true },
    "pg": { "optional": true },
    "better-sqlite3": { "optional": true }
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.7.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.13.4",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "happy-dom": "^17.1.8",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^3.0.7",
    "zod": "^3.24.2"
  },
  "keywords": [
    "ai",
    "agent",
    "llm",
    "chatbot",
    "nextjs",
    "react",
    "streaming",
    "tools",
    "mcp"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/guilhermekoike/agent-sdk"
  }
}
